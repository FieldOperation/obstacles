# Mobile App Environment Variables
# Copy this file to .env in the mobile directory
# For Expo, use EXPO_PUBLIC_ prefix for variables that should be available in the app

# Production API URL
# This will be used when building for production
# Example: EXPO_PUBLIC_API_URL=https://api.yourdomain.com/api
EXPO_PUBLIC_API_URL=https://your-production-api.com/api

# Development API URL (optional)
# If not set, defaults to:
# - Android Emulator: http://10.0.2.2:3001/api
# - iOS Simulator: http://localhost:3001/api
# EXPO_PUBLIC_DEV_API_URL=http://192.168.1.100:3001/api
