# Mobile App Environment Variables
# Copy this file to .env in the mobile directory
# Same Supabase config as the web app (frontend/.env.local)

# Supabase - from Supabase Dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: For push notifications. Get from https://expo.dev → your project → Settings.
# If missing, Expo Go may still register a token; for production/EAS builds set this or extra.eas.projectId in app.json.
# EXPO_PUBLIC_PROJECT_ID=your-eas-project-id
